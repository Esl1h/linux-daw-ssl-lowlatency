#!/usr/bin/env bash
# daw-alsa-ssl - exclusive ALSA access for DAWs running under PipeWire.
#
# Frees the audio interface from PipeWire (profile "off"), opens the DAW
# with exclusive ALSA access at the lowest possible latency, and hands the
# card back to PipeWire when the DAW quits (so the browser/streaming can
# play through it again).
#
# Usage:   daw-alsa-ssl /path/to/daw [args...]
#
# The target card is chosen by DAW_ALSA_CARD (the PipeWire device name, as
# shown by `wpctl status` / `pw-dump`). It defaults to the SSL 2+ MkII.
# Find yours with:  wpctl status | grep -i <your-interface>
# or:  pw-dump | grep device.name
#
# Ex.: DAW_ALSA_CARD="alsa_card.usb-Focusrite..." daw-alsa-ssl /opt/REAPER/reaper
set -uo pipefail

CARD_MATCH="${DAW_ALSA_CARD:-alsa_card.usb-Solid_State_Logic_SSL_2__Mk_II-00}"

# Find the PipeWire device id and its active profile, matching by name.
read_dev() {
  pw-dump 2>/dev/null | python3 - "$CARD_MATCH" <<'PY'
import json, sys
match = sys.argv[1]
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for o in data:
    info = o.get("info") or {}
    props = info.get("props") or {}
    if props.get("device.name") == match:
        idx = 1  # sensible fallback: default active profile
        for p in (info.get("params") or {}).get("Profile", []):
            if p.get("index") is not None:
                idx = p["index"]
        print(o.get("id"), idx)
        break
PY
}

if [ "$#" -eq 0 ]; then
  echo "usage: daw-alsa-ssl /path/to/daw [args...]" >&2
  exit 2
fi

DEV_LINE="$(read_dev)"
DEV_ID="${DEV_LINE%% *}"
PREV_PROFILE="${DEV_LINE##* }"
[ -z "${PREV_PROFILE//[0-9]/}" ] || PREV_PROFILE=1

restore() {
  [ -n "${DEV_ID:-}" ] && command -v wpctl >/dev/null 2>&1 \
    && wpctl set-profile "$DEV_ID" "${PREV_PROFILE:-1}" >/dev/null 2>&1
}
trap restore EXIT INT TERM

if [ -n "${DEV_ID:-}" ] && command -v wpctl >/dev/null 2>&1; then
  wpctl set-profile "$DEV_ID" 0 >/dev/null 2>&1  # 0 = off -> frees the hw for ALSA
  sleep 0.4
else
  echo "daw-alsa-ssl: interface '$CARD_MATCH' not found in PipeWire;" \
       "launching the DAW anyway." >&2
fi

"$@"
