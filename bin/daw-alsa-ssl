#!/usr/bin/env bash
# daw-alsa-ssl - Estrategia A (ALSA exclusivo) para DAWs sob PipeWire.
#
# Libera a interface de audio do PipeWire (perfil "off"), abre o DAW em
# ALSA exclusivo com a menor latencia possivel e devolve a placa ao
# PipeWire quando o DAW fecha (para o navegador/streaming voltarem a tocar).
#
# Uso:   daw-alsa-ssl /caminho/do/daw [args...]
#
# A placa alvo e escolhida por DAW_ALSA_CARD (nome do device no PipeWire,
# como aparece em `wpctl status` / `pw-dump`). O padrao e a SSL 2+ MkII.
# Descubra o nome da sua com:  wpctl status | grep -i <sua-interface>
# ou:  pw-dump | grep device.name
#
# Ex.: DAW_ALSA_CARD="alsa_card.usb-Focusrite..." daw-alsa-ssl /opt/REAPER/reaper
set -uo pipefail

CARD_MATCH="${DAW_ALSA_CARD:-alsa_card.usb-Solid_State_Logic_SSL_2__Mk_II-00}"

# Descobre o id do device no PipeWire e o perfil ativo, casando pelo nome.
read_dev() {
  pw-dump 2>/dev/null | python3 - "$CARD_MATCH" <<'PY'
import json, sys
match = sys.argv[1]
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for o in data:
    info = o.get("info") or {}
    props = info.get("props") or {}
    if props.get("device.name") == match:
        idx = 1  # fallback razoavel: perfil ativo padrao
        for p in (info.get("params") or {}).get("Profile", []):
            if p.get("index") is not None:
                idx = p["index"]
        print(o.get("id"), idx)
        break
PY
}

if [ "$#" -eq 0 ]; then
  echo "uso: daw-alsa-ssl /caminho/do/daw [args...]" >&2
  exit 2
fi

DEV_LINE="$(read_dev)"
DEV_ID="${DEV_LINE%% *}"
PREV_PROFILE="${DEV_LINE##* }"
[ -z "${PREV_PROFILE//[0-9]/}" ] || PREV_PROFILE=1

restore() {
  [ -n "${DEV_ID:-}" ] && command -v wpctl >/dev/null 2>&1 \
    && wpctl set-profile "$DEV_ID" "${PREV_PROFILE:-1}" >/dev/null 2>&1
}
trap restore EXIT INT TERM

if [ -n "${DEV_ID:-}" ] && command -v wpctl >/dev/null 2>&1; then
  wpctl set-profile "$DEV_ID" 0 >/dev/null 2>&1  # 0 = off -> hw livre para o ALSA
  sleep 0.4
else
  echo "daw-alsa-ssl: interface '$CARD_MATCH' nao encontrada no PipeWire;" \
       "abrindo o DAW mesmo assim." >&2
fi

"$@"
